# Catgirl Agentic Runtime Configuration

[global]
max_task_depth = 3
max_queue_size = 1000

[database]
host = "localhost"
port = 5432
user = "catgirl"
password = "your_password_here"
dbname = "catgirl"
sslmode = "disable"

[llm]
# Global LLM settings
embedding_dims = 1024
max_tokens = 4096
timeout_seconds = 120

# LLM providers (global - used for both GP and Reasoner models across all bots)
[[llm.providers]]
base_url = "https://api.openai.com/v1"
api_key = "your_api_key_here"
models = ["gpt-4o", "gpt-4-turbo"]

# Embedding providers (global - used for RAG memory embeddings)
[[llm.embedding_providers]]
base_url = "https://api.openai.com/v1"
api_key = "your_api_key_here"
models = ["text-embedding-3-large"]

[agent_pool]
min_agents = 5
max_agents = 50
idle_timeout_seconds = 300

[snapshots]
enabled = true
storage_path = "/var/catgirl/snapshots"
max_storage_bytes = 10737418240
[snapshots.retention]
completed = "7d"
failed = "30d"
exited = "7d"
interrupted = "14d"

[telegram]
listen_addr = "0.0.0.0:8081"

# Telegram bot configuration (prompts, tools, and model selection are per-bot)
[[telegram.bots]]
bot_token = "your_telegram_bot_token_here"
webhook_url = "https://your-domain.com/telegram/webhook"

# Model selection (leave empty to use random model from global providers)
gp_model = ""
reasoner_model = ""

# Prompts for this bot (leave empty for no system prompt)
orchestrator_system_prompt = ""
agent_system_prompt = ""

# Allowed tools for this bot (leave empty to allow all from global tools table)
allowed_orchestrator_tools = []
allowed_agent_tools = []

[server]
host = "0.0.0.0"
port = 8080

[auth]
# MTFPass authentication URL (only admin role is allowed to login)
mtfpass_url = "https://auth.mtf.edu.ci"

[context]
max_tokens = 128000
compaction_threshold = 0.8
preserve_recent_turns = 20
compaction_agent_type = "reasoner"

[rag]
enabled = true
default_top_k = 5
auto_retrieve.enabled = true
auto_retrieve.on_llm_call = true
auto_retrieve.top_k = 3
auto_retrieve.max_results = 10
min_similarity = 0.7

[logging]
level = "info"
format = "json"
